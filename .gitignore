# ---------------------------------------------------------------------------
# rag-blocks .gitignore  (Python library, GitHub "Python" template + project)
# ---------------------------------------------------------------------------

# Local scratch / generated docs (not part of the repo)
tump_docs/
hotpotqa_generation/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
# Anchored to the repo root: this is setuptools' top-level MANIFEST artifact.
# Unanchored "MANIFEST" also matches studio/app/src/manifest/ on case-insensitive
# filesystems (Windows core.ignorecase), silently dropping tracked source.
/MANIFEST

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# Type checkers / linters
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Secrets (never commit) — see AGENTS.md §7.4
*.pem
*.key

# Jupyter Notebook
.ipynb_checkpoints
# Local scratch notebooks (executed outputs / dotenv workflow — keep local)
examples/*.ipynb

# IDEs / editors
.idea/
.vscode/
*.swp
*.swo
*~

# OS cruft
.DS_Store
Thumbs.db

# Project-local caches (blob store, parse cache, trial logs when run locally)
.rag_cache/
*.sqlite
*.sqlite3

# rag-blocks Studio (optional React app) — node deps and build output.
# app/public/blocks.json IS committed (generated, but ships with the static site).
studio/app/node_modules/
studio/app/dist/
studio/app/.vite/
# The release step copies the built app here to bundle it into the wheel; it is
# a build artifact, never committed (hatch `artifacts` includes it when present).
rag_blocks/studio/_dist/
