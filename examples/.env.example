# Copy to examples/.env and fill in the values you need. Never commit .env
# (it is gitignored). Every key is optional — components read them as a
# fallback and raise an actionable error only when you actually use them.

# --- LLM / generation ---
ANTHROPIC_API_KEY=

# --- OCR engines ---
MISTRAL_API_KEY=
# Google Document AI uses application-default credentials, not a key here:
#   gcloud auth application-default login
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_DOCAI_PROCESSOR=

# --- Object storage (MinIO / S3-compatible) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=rag-blocks
MINIO_SECURE=false

# --- Vector store ---
QDRANT_URL=http://localhost:6333

# --- Integration tests ---
# Absolute path to a local PDF used by opt-in integration tests.
RAG_BLOCKS_TEST_PDF=
